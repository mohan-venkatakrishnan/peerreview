# PeerReview environment — copy to .env and fill in.
# Mirrors LaunchPad's stack (AWS Cognito + API Gateway + Lambda + DynamoDB).
# NOTE: every VITE_* value is embedded in the shipped JS and is PUBLIC.
# Secrets (AWS keys, Google client secret, LemonSqueezy) are used by
# Terraform/Lambda only and never reach the frontend bundle.

# --- AWS (Terraform / deploy scripts only — never shipped) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# --- Google OAuth (pasted into Cognito via Terraform — never shipped) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LemonSqueezy (webhook Lambda only) ---
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_API_KEY=

# --- Frontend (public by design, LaunchPad naming) ---
VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
VITE_API_URL=
VITE_SITE_URL=https://peerreview.tapdot.org
# true = run against src/data/mock.js with no backend (current behaviour)
VITE_USE_MOCK=true
